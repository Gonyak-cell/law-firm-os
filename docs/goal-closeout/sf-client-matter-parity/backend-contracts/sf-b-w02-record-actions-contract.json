  "route_policy_contract": [
    {
      "route": "GET /api/record-actions/:object_name/fields",
      "action": "record_action:field_registry:read",
      "resource_type": "record_action_field_registry",
      "permission_gate": "fail_closed_x_lawos_permission_context",
      "safe_response_invariant": "allowlisted field metadata only; unsafe fields omitted"
    },
    {
      "route": "GET /api/record-actions/:object_name/bulk-actions",
      "action": "record_action:bulk_registry:read",
      "resource_type": "record_action_bulk_registry",
      "permission_gate": "fail_closed_x_lawos_permission_context",
      "safe_response_invariant": "safe action metadata and approval requirements only"
    },
    {
      "route": "POST /api/record-actions/:object_name/:record_id/field-update",
      "action": "record_action:field_update",
      "resource_type": "record_action_field_update",
      "permission_gate": "fail_closed_x_lawos_permission_context",
      "idempotency": "idempotency_key persisted in object audit repository",
      "audit": "record_action.field_updated",
      "safe_response_invariant": "changed fields and safe record summary only; no raw tenant/user/contact values"
    },
    {
      "route": "POST /api/record-actions/:object_name/bulk-updates",
      "action": "record_action:bulk_update",
      "resource_type": "record_action_bulk_update",
      "permission_gate": "fail_closed_x_lawos_permission_context",
      "idempotency": "idempotency_key persisted in object audit repository",
      "audit": "record_action.<action_type>.completed or .blocked",
      "safe_response_invariant": "all-or-blocked counts; unsupported owner/export effects return owner/provider blocked state"
    },
    {
      "route": "GET /api/record-actions/:object_name/:record_id/audit",
      "action": "record_action:audit:read",
      "resource_type": "record_action_audit",
      "permission_gate": "fail_closed_x_lawos_permission_context",
      "safe_response_invariant": "actor refs and raw values omitted"
    }
  ],
  "repository_service_contract": {
    "package": "packages/record-actions",
    "service": "createRecordActionService",
    "repositories": [
      "matter_runtime_repository",
