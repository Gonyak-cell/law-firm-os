  "no_go_policy": {
    "partial_pass_carryover": "forbidden",
    "missing_or_failed_dimension_result": "no_go",
    "p0_p1_adjudication_required_before_rejudgment": true,
    "full_gate_rejudgment_required_after_fix": true,
    "local_waiver_without_owner_approval": "forbidden",
    "review_waiver_counts_as_valid_review_evidence": false
  },
  "non_weakening_clause": [
    "Closed CP evidence is read-only and must not be rewritten to satisfy go-live.",
    "Go-live readiness is an additive gate above production_ready and runtime_ready.",
    "Lower gate output cannot be implied or substituted by a higher gate document.",
    "Synthetic validation fixtures prove validator behavior only and do not prove live go-readiness.",
    "Human signoff remains required for G10 and cannot be synthesized by automation."
  ]
